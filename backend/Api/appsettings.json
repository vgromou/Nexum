{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning",
      "Microsoft.EntityFrameworkCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "IpRateLimiting": {
    "EnableEndpointRateLimiting": true,
    "StackBlockedRequests": false,
    "RealIpHeader": "X-Forwarded-For",
    "ClientIdHeader": "X-ClientId",
    "HttpStatusCode": 429,
    "GeneralRules": [
      {
        "Endpoint": "POST:/api/auth/login",
        "Period": "1m",
        "Limit": 10
      },
      {
        "Endpoint": "POST:/api/auth/logout",
        "Period": "1m",
        "Limit": 30
      },
      {
        "Endpoint": "POST:/api/auth/refresh",
        "Period": "1m",
        "Limit": 30
      },
      {
        "Endpoint": "POST:/api/organizations",
        "Period": "1m",
        "Limit": 5
      },
      {
        "Endpoint": "POST:/api/admin/users/*/reset-password",
        "Period": "1m",
        "Limit": 5
      }
    ]
  },
  "ConnectionStrings": {
    "DefaultConnection": "Host=localhost;Port=5432;Database=nexum;Username=postgres;Password=postgres"
  },
  "Jwt": {
    "Secret": "",
    "Issuer": "nexum-api",
    "Audience": "nexum-client",
    "AccessTokenExpirationMinutes": 15,
    "RefreshTokenExpirationDays": 7
  },
  "Security": {
    "MaxFailedLoginAttempts": 5,
    "LockoutDurationMinutes": 15,
    "TemporaryPasswordLength": 16,
    "TokenCleanupIntervalHours": 24,
    "RevokedTokenRetentionDays": 30,
    "MaxActiveSessionsPerUser": 10,
    "EnforceTokenIpBinding": false
  }
}
